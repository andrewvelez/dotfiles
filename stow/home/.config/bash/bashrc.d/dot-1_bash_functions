list_services() {
  local _svdir="${SVDIR:-/var/service}"
  sudo sv check "${_svdir}"/*
}
export -f "list_services"

test_substring() {
  case "$1" in
    *"$2"*) return 0 ;;
    *) return 1 ;;
  esac
}
export -f "test_substring"

find_lines_in_files() {
  sudo rg -Fi. "$1" /
}
export -f "find_lines_in_files"

find_filenames() {
  sudo fd -t f "$1" /
}
export -f "find_filenames"

add_dir_path() {
  # add-path-dir func must remain with {} because it's modifying PATH

  if [ -z "$1" ] || ! [ -d "$2" ]; then
    return 1
  fi

  if ! test_substring ":${!1}:" ":${2}:"; then
    eval "$1=\"${2}:${!1}\""
  fi
}
export -f "add_dir_path"

open_file_editor() {
  code-oss -r "$@" > /dev/null 2>&1
}
export -f "open_file_editor"

# Source - https://stackoverflow.com/a
# Posted by Rucent88
# Retrieved 2025-12-24, License - CC BY-SA 4.0
sudo_plus() {
  [[ "$(type -t "$1")" == "function" ]] && sudo bash -c "$(declare -f "$1"); $*"
}
export -f "sudo_plus"

# Gives the log since the last machine boot up with the UTC time fixed (but hardcoded.)
# Had heavy help from AI.
logs_since_boot() {
  sudo cat /var/log/socklog/*/current | sort -u | 
    tac | sed '/===== BOOT SENTINEL: socklog is alive/q' | tac |
    perl -MTime::Piece -ne '
      if (/^([\d-]+T[\d:.]+)(.*)/) {
        my ($dt_str, $rest) = ($1, $2);
        $dt_str =~ s/\.\d+$//; # Strip fractional seconds
        
        # Parse as UTC, convert to local system time automatically
        my $t = Time::Piece->strptime($dt_str, "%Y-%m-%dT%H:%M:%S");
        print $t->localtime->datetime . " " . $rest . "\n";
      } else {
        print $_;
      }
    ' |
    bat -l log
}
export -f "logs_since_boot"
