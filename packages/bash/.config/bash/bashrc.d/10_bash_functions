sudo_plus() {
  [[ "$(type -t "$1")" == "function" ]] && sudo bash -c "$(declare -f "$1"); $*"
}
export -f "sudo_plus"

new_repo() {
  [[ -z $1 || -d $1 ]] && return 1

  if ! { gh auth status && gh repo create "$1" --public --clone --gitignore Node; } > /dev/null; then
    echo "error creating github repo" && return 1
  fi

  cd "$1" || return 1

  if ! { rad auth && rad init --name "$1" --description "$1" --default-branch main --private --no-confirm; } > /dev/null; then
    echo "error creating radical repo" && return 1
  fi

  local _rad_url
  _rad_url="$(rad .)"

  if ! { git remote set-url --add --push origin "git@github.com:andrewvelez/$1.git" && git remote set-url --add --push origin "${_rad_url}"; } > /dev/null; then
    echo "error setting remotes" && return 1
  fi

  cd ".."
}
export -f "new_repo"
